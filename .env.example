# ---------------------------------------------------------------------------
# Simola HOA Portal — environment variables
# This is a static informational PWA. There is NO database and NO auth.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# cPanel/live-site form handler URL (POST multipart/form-data).
# Required for form submissions to email office@simolahoa.co.za.
NEXT_PUBLIC_FORM_EMAIL_ENDPOINT="https://example.com/api/forms"
