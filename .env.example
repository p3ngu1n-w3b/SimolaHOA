# ---------------------------------------------------------------------------
# Simola HOA Portal — environment variables
# Copy to .env and fill in values.
# ---------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL="postgresql://simola:simola@localhost:5432/simola?schema=public"

# NextAuth / Auth.js
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
# Base URL of the deployment (used for callbacks). Optional in dev.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Public site URL (used for SEO / sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Seed admin credentials (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@simolahoa.co.za"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# File uploads
# Where local uploads are stored relative to /public. Files are served from /uploads.
UPLOAD_DIR="public/uploads"
MAX_UPLOAD_MB="10"

# Email (optional — notifications). Leave blank to log to console instead.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="Simola HOA <no-reply@simolahoa.co.za>"
ADMIN_NOTIFY_EMAIL="office@simolahoa.co.za"
